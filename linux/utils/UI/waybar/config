{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 5,
    "modules-left": [
        "battery",
        "memory",
        "cpu",
        "hyprland/window"
    ],
    "modules-center": [],
    "modules-right": [
        "network",
        "pulseaudio",
        "backlight",
        "clock",
        "tray"
    ],
    "hyprland/window": {
        "format": "\uf061 {}",
        "separate-outputs": true
    },
    "tray": {
        "icon-size": 21,
        "spacing": 5
    },
    "clock": {
        "interval": 1,
        "format": "\uf017 {:%H:%M:%S}",
        "format-alt": "\uf133 {:%Y-%m-%d %H:%M:%S}"
    },
    "cpu": {
        "interval": 1,
        "format": " \uf2db {usage:2}%",
        "tooltip": false
    },
    "memory": {
        "interval": 1,
        "format": " \uf233 {used:4.1f}G",
        "tooltip": false
    },
    "network": {
        "interval": 1,
        "format-wifi": " \uf1eb {essid}{signalStrength:3}%",
        "format-ethernet": "\uf796 {bandwidthUpBits} {bandwidthDownBits}",
        "format-linked": " \uf1ad {ifname} (No IP)",
        "format-disconnected": "\u26a0 Disconnected",
        "tooltip-format": " \uf1ad {ifname} {ipaddr}/{cidr} via {gwaddr}",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity:3}%",
        "format-charging": " \uf1e6 {capacity:3}%",
        "format-plugged": " \uf1e6 {capacity:3}%",
        "format-full": " \uf240 {capacity:3}%",
        "format-icons": [
            "\uf244",
            "\uf242",
            "\uf240"
        ],
        "tooltip": false
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume:3}%",
        "format-muted": " \uf026 {volume:3}%",
        "format-bluetooth": "{icon}\uf1e7{volume:3}%",
        "format-bluetooth-muted": " \uf026\uf1e7",
        "format-icons": {
            "headphone": " \uf025",
            "hands-free": " \uf590",
            "headset": " \uf590",
            "phone": " \uf095",
            "portable": " \uf095",
            "car": " \uf1b9",
            "default": [
                " \uf026",
                " \uf027",
                " \uf028"
            ]
        },
        "on-click-right": "pavucontrol"
    },
    "backlight": {
        "min": 0,
        "max": 100,
        "format": "{icon} {percent:3}%",
        "format-icons": [
            "\uf10c",
            "\uf192",
            "\uf111"
        ]
    }
}